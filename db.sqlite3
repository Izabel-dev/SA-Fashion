{% extends 'base.html' %}
{% block title %}Lista de Categorias{% endblock %}
{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Categorias de Produtos</h2>
    <a href="{% url 'categoria_create' %}" class="btn btn-success">Nova Categoria</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            {% for categoria in categorias %}
            <tr>
                <td>{{ categoria.nome }}</td>
                <td>{{ categoria.descricao|default:"-" }}</td>
                <td>
                    <a href="{% url 'categoria_update' categoria.pk %}" class="btn btn-sm btn-warning">Editar</a>
                    <a href="{% url 'categoria_delete' categoria.pk %}" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
            {% empty %}
            <tr>
                <td colspan="3" class="text-center">Nenhuma categoria cadastrada.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
